      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .benefits-section {\n    padding: 4rem 2rem;\n    text-align: center;\n    font-family: sans-serif;\n  }\n  .benefits-label {\n    font-size: 13px;\n    font-weight: 500;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: #5a7a4a;\n    margin-bottom: 0.75rem;\n  }\n  .benefits-title {\n    font-size: 2.4rem;\n    font-weight: 500;\n    color: #1a1a1a;\n    margin: 0 0 0.75rem;\n    line-height: 1.2;\n  }\n  .benefits-subtitle {\n    font-size: 1rem;\n    color: #666;\n    margin: 0 auto 3rem;\n    max-width: 520px;\n    line-height: 1.7;\n  }\n  .benefits-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 2rem 1.5rem;\n    max-width: 860px;\n    margin: 0 auto;\n  }\n  .benefit-card {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 1rem;\n  }\n  .benefit-icon-wrap {\n    width: 72px;\n    height: 72px;\n    border-radius: 50%;\n    background: #f0f5eb;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n  .benefit-icon-wrap i {\n    font-size: 30px;\n    color: #4a7a35;\n  }\n  .benefit-name {\n    font-size: 1rem;\n    font-weight: 500;\n    color: #1a1a1a;\n    margin: 0 0 0.3rem;\n  }\n  .benefit-desc {\n    font-size: 0.875rem;\n    color: #666;\n    line-height: 1.6;\n    margin: 0;\n  }\n  @media (max-width: 620px) {\n    .benefits-grid {\n      grid-template-columns: repeat(2, 1fr);\n      gap: 2rem 1rem;\n    }\n    .benefits-title {\n      font-size: 1.75rem;\n    }\n  }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" />\n\n<section class=\"benefits-section\">\n  <p class=\"benefits-label\">Why choose us</p>\n  <h2 class=\"benefits-title\">Ancient Herbs. Modern You.</h2>\n  <p class=\"benefits-subtitle\">Every blend is crafted with intention — sourced from nature, designed for your daily ritual.</p>\n\n  <div class=\"benefits-grid\">\n\n    <div class=\"benefit-card\">\n      <div class=\"benefit-icon-wrap\">\n        <i class=\"ti ti-leaf\" aria-hidden=\"true\"></i>\n      </div>\n      <div>\n        <p class=\"benefit-name\">100% Organic</p>\n        <p class=\"benefit-desc\">Pure, natural ingredients with no additives, preservatives, or artificial flavors.</p>\n      </div>\n    </div>\n\n    <div class=\"benefit-card\">\n      <div class=\"benefit-icon-wrap\">\n        <i class=\"ti ti-heart-rate-monitor\" aria-hidden=\"true\"></i>\n      </div>\n      <div>\n        <p class=\"benefit-name\">Health-Focused</p>\n        <p class=\"benefit-desc\">Each blend is formulated to support your body, mind, and daily wellness goals.</p>\n      </div>\n    </div>\n\n    <div class=\"benefit-card\">\n      <div class=\"benefit-icon-wrap\">\n        <i class=\"ti ti-flask\" aria-hidden=\"true\"></i>\n      </div>\n      <div>\n        <p class=\"benefit-name\">Thoughtfully Sourced</p>\n        <p class=\"benefit-desc\">Premium herbs carefully selected from trusted origins for maximum potency.</p>\n      </div>\n    </div>\n\n    <div class=\"benefit-card\">\n      <div class=\"benefit-icon-wrap\">\n        <i class=\"ti ti-cup\" aria-hidden=\"true\"></i>\n      </div>\n      <div>\n        <p class=\"benefit-name\">Rich, Organic Taste</p>\n        <p class=\"benefit-desc\">Flavor that feels as good as it tastes — earthy, warm, and naturally satisfying.</p>\n      </div>\n    </div>\n\n  </div>\n</section>",

    "custom_liquid_FgUh9V": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n==================================================================\n  TEA (Brew your Health) — HOMEPAGE  (single Custom Liquid block)\n  Customize > Home page > Add section > Custom Liquid > paste all.\n  Multi-product organic herbal tea store.\n  Layout: Announcement · Header · Slideshow · Product grid ·\n          Featured band · Brand story · Trust icons · Footer\n          (+ Popup · Privacy banner · Cart drawer)\n  EDIT the product handles / names / blurbs below to match your store.\n==================================================================\n{%- endcomment -%}\n\n{%- comment -%} Edit these 3 lists in the same order. Use \",\" for handles/names, \"|\" for blurbs. {%- endcomment -%}\n{%- assign handles = \"ashwagandha,stress-less,clean-breath,black-tea,energizer\" | split: \",\" -%}\n{%- assign names   = \"Ashwagandha,Stress Less,Clean Breath,Black Tea,Energizer\" | split: \",\" -%}\n{%- assign blurbs  = \"Ancient adaptogen for stress balance, energy & clear focus.|Ashwagandha, valerian, lavender & chamomile to help you drift off.|Thyme, sage & rosemary to soothe the throat and clear the airways.|A four-leaf master-blend of organic Ceylon black tea.|Clean energy, sharp focus & metabolic vitality.\" | split: \"|\" -%}\n\n{%- comment -%} hero/featured = first product in the store (auto). {%- endcomment -%}\n{%- assign hero = collections.all.products.first -%}\n{%- unless hero -%}{%- assign hero = all_products[handles[0]] -%}{%- endunless -%}\n\n<style>\n  #tea-home{--green:#2F5D3A;--accent:#4F8A3D;--light:#F3F7ED;--text:#566150;--border:#E1E8DA;--gold:#D4A437;--sale:#B45309;\n    font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;color:var(--green);line-height:1.6;}\n  #tea-home *{box-sizing:border-box;}\n  #tea-home img{max-width:100%;display:block;}\n  #tea-home .wrap{max-width:1140px;margin:0 auto;padding:0 20px;}\n  #tea-home .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:var(--accent);color:#fff;font-weight:700;font-size:16px;border:none;border-radius:999px;padding:14px 30px;cursor:pointer;text-decoration:none;box-shadow:0 8px 24px rgba(79,138,61,.3);transition:transform .15s,box-shadow .15s;}\n  #tea-home .btn:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(79,138,61,.42);}\n  #tea-home .stars{color:var(--gold);letter-spacing:2px;}\n  #tea-home .h2{font-size:32px;font-weight:800;text-align:center;margin:0 0 8px;}\n  #tea-home .lead{text-align:center;color:var(--text);max-width:620px;margin:0 auto 36px;}\n  #tea-home .sect{padding:56px 0;}\n  #tea-home .alt{background:var(--light);}\n\n  /* announcement */\n  #tea-home .ann{background:var(--green);color:#fff;overflow:hidden;}\n  #tea-home .ann-track{display:flex;gap:60px;white-space:nowrap;padding:10px 0;animation:tea-ann 25s linear infinite;}\n  #tea-home .ann:hover .ann-track{animation-play-state:paused;}\n  #tea-home .ann span{font-size:13px;font-weight:600;letter-spacing:.4px;}\n  @keyframes tea-ann{from{transform:translateX(0);}to{transform:translateX(-50%);}}\n\n  /* header */\n  #tea-home .hdr{background:#fff;border-bottom:1px solid #EEF2E9;position:sticky;top:0;z-index:40;}\n  #tea-home .hdr-in{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;max-width:1140px;margin:0 auto;}\n  #tea-home .hdr-logo{font-size:24px;font-weight:800;color:var(--green);text-decoration:none;letter-spacing:.5px;}\n  #tea-home .hdr-logo span{color:var(--accent);}\n  #tea-home .hdr-nav{display:flex;gap:26px;}\n  #tea-home .hdr-nav a{color:var(--green);text-decoration:none;font-weight:600;font-size:15px;}\n  #tea-home .hdr-nav a:hover{color:var(--accent);}\n  #tea-home .hdr-act{display:flex;align-items:center;gap:18px;}\n  #tea-home .hdr-act a,#tea-home .hdr-act button{background:none;border:none;cursor:pointer;color:var(--green);text-decoration:none;display:flex;padding:0;}\n  #tea-home .hdr-act svg{width:22px;height:22px;}\n  #tea-home .hdr-cart{position:relative;}\n  #tea-home .hdr-count{position:absolute;top:-8px;right:-10px;background:var(--accent);color:#fff;font-size:11px;font-weight:700;min-width:18px;height:18px;border-radius:9px;display:flex;align-items:center;justify-content:center;padding:0 4px;}\n  @media(max-width:760px){#tea-home .hdr-nav{display:none;}}\n\n  /* slideshow */\n  #tea-home .ss{position:relative;overflow:hidden;}\n  #tea-home .ss-track{display:flex;transition:transform .6s ease;}\n  #tea-home .ss-slide{min-width:100%;position:relative;}\n  #tea-home .ss-slide img{width:100%;height:560px;object-fit:cover;}\n  #tea-home .ss-ph{width:100%;height:560px;background:linear-gradient(120deg,#2F5D3A,#4F8A3D);}\n  #tea-home .ss-ph.b{background:linear-gradient(120deg,#1f4a2c,#3f7a4e);}\n  #tea-home .ss-ov{position:absolute;inset:0;background:linear-gradient(90deg,rgba(20,46,28,.62),rgba(20,46,28,.15));}\n  #tea-home .ss-content{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;max-width:1140px;margin:0 auto;padding:0 40px;color:#fff;}\n  #tea-home .ss-content .eyebrow{font-size:13px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;opacity:.9;margin-bottom:10px;}\n  #tea-home .ss-content h2{font-size:clamp(28px,5vw,52px);font-weight:800;line-height:1.1;margin:0 0 12px;max-width:600px;}\n  #tea-home .ss-content p{font-size:clamp(15px,2vw,20px);margin:0 0 22px;max-width:500px;color:#EAF1E2;}\n  #tea-home .ss-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.85);border:none;width:44px;height:44px;border-radius:50%;cursor:pointer;font-size:22px;color:var(--green);display:flex;align-items:center;justify-content:center;}\n  #tea-home .ss-prev{left:16px;}#tea-home .ss-next{right:16px;}\n  #tea-home .ss-dots{position:absolute;bottom:18px;left:0;right:0;display:flex;justify-content:center;gap:8px;}\n  #tea-home .ss-dot{width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,.5);border:none;cursor:pointer;padding:0;}\n  #tea-home .ss-dot.active{background:#fff;width:24px;border-radius:5px;}\n  @media(max-width:760px){#tea-home .ss-slide img,#tea-home .ss-ph{height:460px;}#tea-home .ss-content{text-align:center;align-items:center;padding:0 24px;}#tea-home .ss-content p{margin-inline:auto;}#tea-home .ss-nav{display:none;}}\n\n  /* product grid */\n  #tea-home .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;}\n  #tea-home .grid a.card{text-decoration:none;color:var(--green);}\n  #tea-home .card{border:1px solid var(--border);border-radius:16px;overflow:hidden;background:#fff;transition:transform .15s,box-shadow .15s;display:flex;flex-direction:column;}\n  #tea-home .card:hover{transform:translateY(-4px);box-shadow:0 14px 30px rgba(47,93,58,.12);}\n  #tea-home .card .ph{width:100%;aspect-ratio:1/1;background:linear-gradient(135deg,#E7EFDD,#cfe0c0);display:flex;align-items:center;justify-content:center;font-size:46px;}\n  #tea-home .card img{width:100%;aspect-ratio:1/1;object-fit:cover;background:var(--light);}\n  #tea-home .card .body{padding:16px;display:flex;flex-direction:column;flex:1;}\n  #tea-home .card .nm{font-weight:800;font-size:16px;margin:0 0 4px;}\n  #tea-home .card .bl{font-size:13px;color:var(--text);margin:0 0 12px;flex:1;}\n  #tea-home .card .pr{color:var(--accent);font-weight:800;font-size:16px;margin-bottom:12px;}\n  #tea-home .card .go{display:block;text-align:center;background:var(--accent);color:#fff;border-radius:999px;padding:11px;font-weight:700;font-size:14px;text-decoration:none;}\n  @media(max-width:980px){#tea-home .grid{grid-template-columns:1fr 1fr;}}\n  @media(max-width:460px){#tea-home .grid{grid-template-columns:1fr;}}\n\n  /* featured band */\n  #tea-home .fp{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;}\n  #tea-home .fp img,#tea-home .fp .ph{width:100%;border-radius:18px;background:var(--light);aspect-ratio:1/1;object-fit:cover;}\n  #tea-home .fp .ph{background:linear-gradient(135deg,#E7EFDD,#cfe0c0);display:flex;align-items:center;justify-content:center;font-size:64px;}\n  #tea-home .fp .eyebrow{color:var(--accent);font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;}\n  #tea-home .fp h2{font-size:32px;font-weight:800;text-align:left;margin:8px 0 12px;}\n  #tea-home .fp p{color:var(--text);font-size:16px;margin:0 0 16px;}\n  #tea-home .fp .price{font-size:26px;font-weight:800;}\n  #tea-home .feat{list-style:none;padding:0;margin:0 0 18px;}\n  #tea-home .feat li{display:flex;gap:10px;margin-bottom:9px;font-size:15px;}\n  #tea-home .feat .ck{color:var(--accent);font-weight:800;}\n  @media(max-width:760px){#tea-home .fp{grid-template-columns:1fr;gap:24px;}#tea-home .fp h2{text-align:center;}}\n\n  /* brand story */\n  #tea-home .band{text-align:center;}\n  #tea-home .band .eyebrow{color:var(--accent);font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;}\n  #tea-home .band h2{font-size:34px;margin:10px 0 16px;}\n  #tea-home .band p{color:var(--text);font-size:17px;max-width:660px;margin:0 auto;}\n\n  /* trust icons */\n  #tea-home .trust{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;}\n  #tea-home .trust .ti{text-align:center;}\n  #tea-home .trust .ti .ico{width:58px;height:58px;border-radius:50%;background:#E7EFDD;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:26px;}\n  #tea-home .trust .ti h3{font-size:16px;margin:0 0 4px;}\n  #tea-home .trust .ti p{font-size:13px;color:var(--text);margin:0;}\n  @media(max-width:760px){#tea-home .trust{grid-template-columns:1fr 1fr;}}\n\n  /* footer */\n  #tea-home .ft{background:var(--green);color:#fff;padding:54px 0 0;}\n  #tea-home .ft a{color:#fff;text-decoration:none;opacity:.85;}#tea-home .ft a:hover{opacity:1;text-decoration:underline;}\n  #tea-home .ft-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1.2fr;gap:40px;padding-bottom:40px;}\n  #tea-home .ft .name{font-size:22px;font-weight:800;}\n  #tea-home .ft p.tag{opacity:.85;font-size:14px;max-width:280px;}\n  #tea-home .ft h4{font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin:0 0 14px;}\n  #tea-home .ft ul{list-style:none;padding:0;margin:0;}#tea-home .ft li{margin-bottom:10px;font-size:14px;}\n  #tea-home .ft .news input{padding:11px 14px;border:none;border-radius:8px;font-size:14px;width:100%;margin-bottom:8px;}\n  #tea-home .ft .news button{background:var(--accent);color:#fff;border:none;border-radius:8px;padding:11px 18px;font-weight:700;cursor:pointer;width:100%;}\n  #tea-home .ft-bottom{border-top:1px solid rgba(255,255,255,.15);padding:20px 0;display:flex;flex-wrap:wrap;gap:14px;justify-content:space-between;align-items:center;}\n  #tea-home .ft-bottom p{margin:0;font-size:13px;opacity:.7;}\n  #tea-home .ft-cod span{background:rgba(255,255,255,.12);border-radius:5px;padding:4px 10px;font-size:12px;font-weight:700;}\n  @media(max-width:760px){#tea-home .ft-grid{grid-template-columns:1fr 1fr;}}\n\n  /* popup */\n  #tea-home .pop{position:fixed;inset:0;background:rgba(20,46,28,.55);z-index:9998;display:none;align-items:center;justify-content:center;padding:20px;}\n  #tea-home .pop.show{display:flex;}\n  #tea-home .pop-box{background:#fff;border-radius:18px;max-width:420px;width:100%;padding:30px;text-align:center;position:relative;box-shadow:0 20px 60px rgba(0,0,0,.3);}\n  #tea-home .pop-box h3{font-size:24px;font-weight:800;margin:0 0 8px;}\n  #tea-home .pop-box p{color:var(--text);margin:0 0 16px;}\n  #tea-home .pop-box input{width:100%;padding:14px;border:2px solid var(--border);border-radius:10px;font-size:15px;margin-bottom:10px;}\n  #tea-home .pop-box .btn{width:100%;}\n  #tea-home .pop-close{position:absolute;top:12px;right:14px;background:none;border:none;font-size:24px;cursor:pointer;color:var(--green);line-height:1;}\n\n  /* privacy */\n  #tea-home .priv{position:fixed;left:0;right:0;bottom:0;z-index:9997;background:var(--green);color:#fff;padding:16px 20px;box-shadow:0 -4px 24px rgba(0,0,0,.18);display:none;}\n  #tea-home .priv.show{display:block;}\n  #tea-home .priv-in{max-width:1140px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:18px;flex-wrap:wrap;}\n  #tea-home .priv-in p{margin:0;font-size:14px;flex:1;min-width:240px;}\n  #tea-home .priv-btns{display:flex;gap:10px;}\n  #tea-home .priv-btns button{border-radius:999px;padding:10px 22px;font-weight:700;font-size:14px;cursor:pointer;border:none;}\n  #tea-home .priv-dec{background:transparent;color:#fff;border:1px solid #fff!important;}#tea-home .priv-acc{background:var(--accent);color:#fff;}\n\n  /* cart drawer */\n  #tea-home .cd-ov{position:fixed;inset:0;background:rgba(20,46,28,.45);z-index:9990;opacity:0;visibility:hidden;transition:opacity .25s;}\n  #tea-home .cd-ov.open{opacity:1;visibility:visible;}\n  #tea-home .cd{position:fixed;top:0;right:0;bottom:0;width:400px;max-width:90vw;background:#fff;z-index:9991;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .3s;}\n  #tea-home .cd.open{transform:translateX(0);}\n  #tea-home .cd-head{display:flex;align-items:center;justify-content:space-between;padding:20px;border-bottom:1px solid #EEF2E9;}\n  #tea-home .cd-head h3{margin:0;font-size:18px;font-weight:800;}\n  #tea-home .cd-close{background:none;border:none;font-size:26px;cursor:pointer;color:var(--green);}\n  #tea-home .cd-items{flex:1;overflow-y:auto;padding:16px 20px;}\n  #tea-home .cd-item{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid #F1F5EC;}\n  #tea-home .cd-item img{width:62px;height:62px;object-fit:cover;border-radius:10px;background:var(--light);}\n  #tea-home .cd-title{font-weight:700;font-size:14px;color:var(--green);text-decoration:none;}\n  #tea-home .cd-qty{display:inline-flex;align-items:center;border:1px solid var(--border);border-radius:8px;margin-top:6px;}\n  #tea-home .cd-qty button{width:28px;height:28px;border:none;background:none;cursor:pointer;font-size:16px;}\n  #tea-home .cd-qty span{width:30px;text-align:center;font-size:13px;font-weight:700;}\n  #tea-home .cd-rm{background:none;border:none;color:#94A3B8;font-size:12px;cursor:pointer;text-decoration:underline;padding:0;margin-top:4px;}\n  #tea-home .cd-foot{padding:20px;border-top:1px solid #EEF2E9;}\n  #tea-home .cd-sub{display:flex;justify-content:space-between;font-weight:800;font-size:16px;margin-bottom:6px;}\n  #tea-home .cd-co{display:block;text-align:center;background:var(--accent);color:#fff;border-radius:999px;padding:15px;font-weight:700;text-decoration:none;}\n  #tea-home .cd-empty{text-align:center;color:#94A3B8;padding:60px 20px;}\n</style>\n\n<div id=\"tea-home\">\n\n  <!-- ANNOUNCEMENT -->\n  <div class=\"ann\"><div class=\"ann-track\">\n    {%- for i in (1..2) -%}\n      <span>🌿 100% organic, ethically sourced</span><span>🚚 FREE delivery on every order</span><span>💵 Cash on Delivery available</span><span>⭐ Loved by tea lovers everywhere</span>\n    {%- endfor -%}\n  </div></div>\n\n  <!-- HEADER -->\n  <header class=\"hdr\"><div class=\"hdr-in\">\n    <a class=\"hdr-logo\" href=\"{{ routes.root_url }}\">Tea<span>.</span></a>\n    <nav class=\"hdr-nav\">\n      <a href=\"{{ routes.root_url }}\">Home</a>\n      <a href=\"{{ routes.all_products_collection_url }}\">Shop</a>\n      <a href=\"/pages/about\">About</a>\n      <a href=\"/pages/contact\">Contact</a>\n    </nav>\n    <div class=\"hdr-act\">\n      <a href=\"{{ routes.search_url }}\" aria-label=\"Search\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"m21 21-4.3-4.3\"/></svg></a>\n      <a href=\"{{ routes.account_url }}\" aria-label=\"Login\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"8\" r=\"4\"/><path d=\"M4 21c0-4 4-6 8-6s8 2 8 6\"/></svg></a>\n      <button class=\"hdr-cart\" onclick=\"teaCartOpen()\" aria-label=\"Cart\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z\"/><path d=\"M3 6h18\"/><path d=\"M16 10a4 4 0 0 1-8 0\"/></svg><span class=\"hdr-count\" id=\"tea-count\">{{ cart.item_count }}</span></button>\n    </div>\n  </div></header>\n\n  <!-- SLIDESHOW -->\n  <section class=\"ss\"><div class=\"ss-track\" id=\"tea-ss-track\">\n    <div class=\"ss-slide\">\n      {%- if hero.featured_image -%}<img src=\"{{ hero.featured_image | image_url: width: 2000 }}\" alt=\"\">{%- else -%}<div class=\"ss-ph\"></div>{%- endif -%}\n      <div class=\"ss-ov\"></div>\n      <div class=\"ss-content\"><div class=\"eyebrow\">Rich, Organic Taste</div><h2>Brew Your Health</h2><p>Hand-blended organic herbal teas for everyday wellness.</p><a class=\"btn\" href=\"{{ routes.all_products_collection_url }}\">Shop All Blends</a></div>\n    </div>\n    <div class=\"ss-slide\">\n      {%- if hero.images[1] -%}<img src=\"{{ hero.images[1] | image_url: width: 2000 }}\" alt=\"\">{%- else -%}<div class=\"ss-ph b\"></div>{%- endif -%}\n      <div class=\"ss-ov\"></div>\n      <div class=\"ss-content\"><div class=\"eyebrow\">Pure & Natural</div><h2>Free Delivery + Cash on Delivery</h2><p>Sourced from the finest growers. No additives, ever.</p><a class=\"btn\" href=\"{{ routes.all_products_collection_url }}\">Discover More</a></div>\n    </div>\n  </div>\n    <button class=\"ss-nav ss-prev\" onclick=\"teaSlide(-1)\" aria-label=\"Prev\">‹</button>\n    <button class=\"ss-nav ss-next\" onclick=\"teaSlide(1)\" aria-label=\"Next\">›</button>\n    <div class=\"ss-dots\"><button class=\"ss-dot active\" onclick=\"teaGoto(0)\"></button><button class=\"ss-dot\" onclick=\"teaGoto(1)\"></button></div>\n  </section>\n\n  <!-- PRODUCT GRID -->\n  <section class=\"sect\"><div class=\"wrap\">\n    <h2 class=\"h2\">Our Blends</h2>\n    <p class=\"lead\">Carefully crafted organic teas — each one made to support a part of your day.</p>\n    <div class=\"grid\">\n      {%- comment -%} Auto-pulls every product in your store — no handle setup needed. {%- endcomment -%}\n      {%- assign storeprods = collections.all.products -%}\n      {%- if storeprods.size > 0 -%}\n        {%- for prod in storeprods limit: 8 -%}\n          <a class=\"card\" href=\"{{ prod.url }}\">\n            {%- if prod.featured_image -%}\n              <img src=\"{{ prod.featured_image | image_url: width: 500 }}\" alt=\"{{ prod.title | escape }}\">\n            {%- else -%}\n              <div class=\"ph\">🍃</div>\n            {%- endif -%}\n            <div class=\"body\">\n              <h3 class=\"nm\">{{ prod.title }}</h3>\n              <p class=\"bl\">{{ prod.description | strip_html | truncatewords: 16 }}</p>\n              <div class=\"pr\">{{ prod.price | money }}</div>\n              <span class=\"go\">Shop Now</span>\n            </div>\n          </a>\n        {%- endfor -%}\n      {%- else -%}\n        {%- comment -%} Fallback placeholders only if the store has no products yet. {%- endcomment -%}\n        {%- for h in handles -%}\n          {%- assign nm = names[forloop.index0] -%}\n          {%- assign bl = blurbs[forloop.index0] -%}\n          <div class=\"card\">\n            <div class=\"ph\">🍃</div>\n            <div class=\"body\">\n              <h3 class=\"nm\">{{ nm }}</h3>\n              <p class=\"bl\">{{ bl }}</p>\n              <a class=\"go\" href=\"{{ routes.all_products_collection_url }}\" style=\"margin-top:auto;\">Coming Soon</a>\n            </div>\n          </div>\n        {%- endfor -%}\n      {%- endif -%}\n    </div>\n  </div></section>\n\n  <!-- FEATURED BAND -->\n  <section class=\"sect alt\"><div class=\"wrap\"><div class=\"fp\">\n    <div>{%- if hero.featured_image -%}<img src=\"{{ hero.featured_image | image_url: width: 800 }}\" alt=\"\">{%- else -%}<div class=\"ph\">🌱</div>{%- endif -%}</div>\n    <div>\n      <span class=\"eyebrow\">Best Seller</span>\n      <h2>{{ hero.title | default: names[0] }}</h2>\n      <ul class=\"feat\">\n        <li><span class=\"ck\">✓</span> 100% organic, single-source ingredients</li>\n        <li><span class=\"ck\">✓</span> No artificial flavors, colors or additives</li>\n        <li><span class=\"ck\">✓</span> Resealable pouch keeps every cup fresh</li>\n        <li><span class=\"ck\">✓</span> Free delivery + cash on delivery</li>\n      </ul>\n      {%- if hero -%}<div style=\"margin-bottom:16px;\"><span class=\"price\">{{ hero.price | money }}</span></div>{%- endif -%}\n      <a class=\"btn\" href=\"{{ hero.url | default: routes.all_products_collection_url }}\">Shop Now</a>\n    </div>\n  </div></div></section>\n\n  <!-- BRAND STORY -->\n  <section class=\"sect band\"><div class=\"wrap\">\n    <span class=\"eyebrow\">Our Promise</span>\n    <h2>Brewed for Better Days</h2>\n    <p>Every Tea blend is sourced from trusted organic growers and packed by hand to preserve aroma, flavor and benefit. No fillers, no shortcuts — just clean, honest ingredients in every cup.</p>\n  </div></section>\n\n  <!-- TRUST ICONS -->\n  <section class=\"sect alt\"><div class=\"wrap\"><div class=\"trust\">\n    <div class=\"ti\"><div class=\"ico\">🌿</div><h3>100% Organic</h3><p>Ethically sourced ingredients.</p></div>\n    <div class=\"ti\"><div class=\"ico\">🚚</div><h3>Free Delivery</h3><p>On every order, no minimum.</p></div>\n    <div class=\"ti\"><div class=\"ico\">💵</div><h3>Cash on Delivery</h3><p>Pay when it arrives.</p></div>\n    <div class=\"ti\"><div class=\"ico\">💬</div><h3>Friendly Support</h3><p>We reply within 24 hours.</p></div>\n  </div></div></section>\n\n  <!-- FOOTER -->\n  <footer class=\"ft\"><div class=\"wrap\">\n    <div class=\"ft-grid\">\n      <div><div class=\"name\">Tea.</div><p class=\"tag\">Hand-blended organic herbal teas. Brew your health, every day.</p></div>\n      <div><h4>Shop</h4><ul>\n        {%- assign ftprods = collections.all.products -%}\n        {%- if ftprods.size > 0 -%}\n          {%- for prod in ftprods limit: 6 -%}\n            <li><a href=\"{{ prod.url }}\">{{ prod.title }}</a></li>\n          {%- endfor -%}\n        {%- else -%}\n          {%- for h in handles -%}\n            <li><a href=\"{{ routes.all_products_collection_url }}\">{{ names[forloop.index0] }}</a></li>\n          {%- endfor -%}\n        {%- endif -%}\n      </ul></div>\n      <div><h4>Help</h4><ul><li><a href=\"/pages/contact\">Contact</a></li><li><a href=\"/pages/shipping\">Shipping</a></li><li><a href=\"/pages/returns\">Returns</a></li></ul></div>\n      <div class=\"news\"><h4>Stay in touch</h4>\n        {%- form 'customer' -%}<input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter,footer\"><input type=\"email\" name=\"contact[email]\" placeholder=\"Your email\" required><button type=\"submit\">Subscribe</button>{%- if form.posted_successfully? -%}<p style=\"color:#bff0b3;margin-top:8px;font-size:13px;\">Subscribed — thank you!</p>{%- endif -%}{%- endform -%}\n      </div>\n    </div>\n    <div class=\"ft-bottom\"><p>© {{ 'now' | date: '%Y' }} Tea. All rights reserved.</p><div class=\"ft-cod\"><span>💵 Cash on Delivery</span></div></div>\n  </div></footer>\n\n  <!-- POPUP -->\n  <div class=\"pop\" id=\"tea-pop\"><div class=\"pop-box\">\n    <button class=\"pop-close\" onclick=\"teaPopClose()\">×</button>\n    <h3>Get 10% Off</h3><p>Sign up and save 10% on your first order.</p>\n    {%- form 'customer' -%}<input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter,popup\"><input type=\"email\" name=\"contact[email]\" placeholder=\"Enter your email\" required><button type=\"submit\" class=\"btn\">Claim My 10%</button>{%- endform -%}\n  </div></div>\n\n  <!-- PRIVACY -->\n  <div class=\"priv\" id=\"tea-priv\"><div class=\"priv-in\"><p>We use cookies to improve your experience and analyze site traffic.</p><div class=\"priv-btns\"><button class=\"priv-dec\" onclick=\"teaConsent('declined')\">Decline</button><button class=\"priv-acc\" onclick=\"teaConsent('accepted')\">Accept</button></div></div></div>\n\n  <!-- CART DRAWER -->\n  <div class=\"cd-ov\" id=\"tea-cd-ov\" onclick=\"teaCartClose()\"></div>\n  <aside class=\"cd\" id=\"tea-cd\" aria-label=\"Cart\">\n    <div class=\"cd-head\"><h3>Your Cart (<span id=\"tea-cd-count\">{{ cart.item_count }}</span>)</h3><button class=\"cd-close\" onclick=\"teaCartClose()\">×</button></div>\n    <div class=\"cd-items\" id=\"tea-cd-items\"></div><div class=\"cd-foot\" id=\"tea-cd-foot\"></div>\n  </aside>\n\n</div>\n\n<script>\n(function(){\n  function fmt(c){ return \"$\"+(c/100).toFixed(2); }\n\n  /* slideshow */\n  var i=0,n=2,track=document.getElementById(\"tea-ss-track\"),dots=document.querySelectorAll(\"#tea-home .ss-dot\");\n  function go(k){ i=(k+n)%n; track.style.transform=\"translateX(-\"+(i*100)+\"%)\"; dots.forEach(function(d,j){d.classList.toggle(\"active\",j===i);}); }\n  window.teaSlide=function(d){ go(i+d); }; window.teaGoto=function(k){ go(k); };\n  setInterval(function(){ go(i+1); },6000);\n\n  /* popup */\n  window.teaPopClose=function(){ document.getElementById(\"tea-pop\").classList.remove(\"show\"); localStorage.setItem(\"tea-popup\",Date.now()); };\n  setTimeout(function(){ var l=localStorage.getItem(\"tea-popup\"); if(!l||(Date.now()-l)>7*864e5) document.getElementById(\"tea-pop\").classList.add(\"show\"); },5000);\n  document.getElementById(\"tea-pop\").addEventListener(\"click\",function(e){ if(e.target.id===\"tea-pop\") teaPopClose(); });\n\n  /* privacy */\n  window.teaConsent=function(c){ localStorage.setItem(\"tea-consent\",c); if(window.Shopify&&Shopify.customerPrivacy){try{Shopify.customerPrivacy.setTrackingConsent(c===\"accepted\");}catch(e){}} document.getElementById(\"tea-priv\").classList.remove(\"show\"); };\n  if(!localStorage.getItem(\"tea-consent\")) document.getElementById(\"tea-priv\").classList.add(\"show\");\n\n  /* cart drawer */\n  var ov=document.getElementById(\"tea-cd-ov\"),cd=document.getElementById(\"tea-cd\"),itemsEl=document.getElementById(\"tea-cd-items\"),footEl=document.getElementById(\"tea-cd-foot\");\n  function render(cart){\n    document.getElementById(\"tea-cd-count\").textContent=cart.item_count;\n    var hc=document.getElementById(\"tea-count\"); if(hc) hc.textContent=cart.item_count;\n    if(cart.item_count===0){ itemsEl.innerHTML='<div class=\"cd-empty\"><p>Your cart is empty.</p></div>'; footEl.innerHTML=\"\"; return; }\n    var h=\"\";\n    cart.items.forEach(function(it,i){\n      h+='<div class=\"cd-item\"><img src=\"'+(it.image?it.image.replace(/(\\.[a-z]+)(\\?|$)/i,\"_120x$1$2\"):\"\")+'\" alt=\"\">'\n       +'<div style=\"flex:1\"><a class=\"cd-title\" href=\"'+it.url+'\">'+it.product_title+'</a>'\n       +(it.variant_title?'<div style=\"font-size:12px;color:#94A3B8\">'+it.variant_title+'</div>':'')\n       +'<div class=\"cd-qty\"><button onclick=\"teaCartChange('+(i+1)+','+(it.quantity-1)+')\">−</button><span>'+it.quantity+'</span><button onclick=\"teaCartChange('+(i+1)+','+(it.quantity+1)+')\">+</button></div>'\n       +'<button class=\"cd-rm\" onclick=\"teaCartChange('+(i+1)+',0)\">Remove</button></div>'\n       +'<div style=\"font-weight:700\">'+fmt(it.final_line_price)+'</div></div>';\n    });\n    itemsEl.innerHTML=h;\n    footEl.innerHTML='<div class=\"cd-sub\"><span>Subtotal</span><span>'+fmt(cart.total_price)+'</span></div><p style=\"font-size:12px;color:#94A3B8;margin:0 0 14px\">Cash on delivery · taxes at checkout.</p><a class=\"cd-co\" href=\"/checkout\">Checkout</a>';\n  }\n  function refresh(){ fetch(\"/cart.js\").then(function(r){return r.json();}).then(render); }\n  window.teaCartOpen=function(){ ov.classList.add(\"open\"); cd.classList.add(\"open\"); document.body.style.overflow=\"hidden\"; refresh(); };\n  window.teaCartClose=function(){ ov.classList.remove(\"open\"); cd.classList.remove(\"open\"); document.body.style.overflow=\"\"; };\n  window.teaCartChange=function(line,qty){ fetch(\"/cart/change.js\",{method:\"POST\",headers:{\"Content-Type\":\"application/json\"},body:JSON.stringify({line:line,quantity:qty})}).then(function(r){return r.json();}).then(render); };\n  refresh();\n})();\n</script>",

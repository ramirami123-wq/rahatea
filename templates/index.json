    "custom_liquid_3w7JfL": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" />\n\n<style>\n  .faq-section {\n    padding: 4rem 2rem;\n    max-width: 720px;\n    margin: 0 auto;\n    font-family: sans-serif;\n  }\n  .faq-label {\n    font-size: 13px;\n    font-weight: 500;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: #5a7a4a;\n    margin-bottom: 0.75rem;\n    text-align: center;\n  }\n  .faq-title {\n    font-size: 2.2rem;\n    font-weight: 500;\n    color: #1a1a1a;\n    text-align: center;\n    margin: 0 0 0.75rem;\n    line-height: 1.2;\n  }\n  .faq-subtitle {\n    font-size: 1rem;\n    color: #666;\n    text-align: center;\n    margin: 0 auto 3rem;\n    max-width: 480px;\n    line-height: 1.7;\n  }\n  .faq-list {\n    display: flex;\n    flex-direction: column;\n    border-top: 1px solid #e0e0d8;\n  }\n  .faq-item {\n    border-bottom: 1px solid #e0e0d8;\n  }\n  .faq-question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 1.25rem 0;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    cursor: pointer;\n    text-align: left;\n    gap: 1rem;\n  }\n  .faq-question span {\n    font-size: 1rem;\n    font-weight: 500;\n    color: #1a1a1a;\n    line-height: 1.5;\n  }\n  .faq-icon {\n    font-size: 20px;\n    color: #4a7a35;\n    flex-shrink: 0;\n    transition: transform 0.25s ease;\n  }\n  .faq-icon.open {\n    transform: rotate(45deg);\n  }\n  .faq-answer {\n    font-size: 0.9375rem;\n    color: #666;\n    line-height: 1.7;\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease, padding 0.3s ease;\n    padding: 0;\n  }\n  .faq-answer.open {\n    max-height: 300px;\n    padding-bottom: 1.25rem;\n  }\n  @media (max-width: 500px) {\n    .faq-title { font-size: 1.7rem; }\n    .faq-section { padding: 3rem 1.25rem; }\n  }\n</style>\n\n<section class=\"faq-section\">\n  <p class=\"faq-label\">Got questions?</p>\n  <h2 class=\"faq-title\">We've got answers</h2>\n  <p class=\"faq-subtitle\">Everything you need to know about our blends, ingredients, and how to brew your best cup.</p>\n\n  <div class=\"faq-list\">\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Are your teas 100% natural and organic?</span>\n        <i class=\"ti ti-plus faq-icon\" aria-hidden=\"true\"></i>\n      </button>\n      <div class=\"faq-answer\">Yes — every blend is made with pure, natural ingredients. We use no additives, artificial flavors, or preservatives. Our herbs are carefully sourced from trusted origins to ensure you get the cleanest, most potent cup possible.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How do I prepare my tea?</span>\n        <i class=\"ti ti-plus faq-icon\" aria-hidden=\"true\"></i>\n      </button>\n      <div class=\"faq-answer\">Mix one teaspoon of your chosen blend with a cup of hot water (not boiling — around 85–90°C is ideal). Stir well and let it steep for 3–5 minutes. Each product page also includes specific preparation tips for that blend.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Can I drink these teas every day?</span>\n        <i class=\"ti ti-plus faq-icon\" aria-hidden=\"true\"></i>\n      </button>\n      <div class=\"faq-answer\">Most of our blends are designed for daily use. However, some herbal blends — like our Ashwagandha — come with specific usage recommendations. Always read the product warnings and consult your doctor if you are pregnant, breastfeeding, or on medication.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>How much does each pouch contain, and how long will it last?</span>\n        <i class=\"ti ti-plus faq-icon\" aria-hidden=\"true\"></i>\n      </button>\n      <div class=\"faq-answer\">Each pouch contains 100g of tea. With one teaspoon per serving, a single pouch gives you approximately 40–50 cups — that's over a month of daily brewing for most people.</div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        <span>Do you ship internationally?</span>\n        <i class=\"ti ti-plus faq-icon\" aria-hidden=\"true\"></i>\n      </button>\n      <div class=\"faq-answer\">Yes! We ship to most countries worldwide. Shipping times and fees vary by destination. All orders are carefully packaged to keep your blends fresh during transit. Check the checkout page for delivery options available in your region.</div>\n    </div>\n\n  </div>\n</section>\n\n<script>\n  function toggleFaq(btn) {\n    const answer = btn.nextElementSibling;\n    const icon = btn.querySelector('.faq-icon');\n    const isOpen = answer.classList.contains('open');\n    document.querySelectorAll('.faq-answer.open').forEach(a => {\n      a.classList.remove('open');\n      a.previousElementSibling.querySelector('.faq-icon').classList.remove('open');\n    });\n    if (!isOpen) {\n      answer.classList.add('open');\n      icon.classList.add('open');\n    }\n  }\n</script>",
        "full_width": false,
        "show_section_divider": false,
        "padding_top": 28,
        "padding_bottom": 28,
        "full_width_mobile": false,
        "show_section_divider_mobile": false,
        "padding_top_mobile": 28,

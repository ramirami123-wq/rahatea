        "custom_liquid": "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" />\n\n<style>\n  .guarantees-section {\n    padding: 4rem 2rem;\n    background: #f7f5f0;\n    font-family: sans-serif;\n  }\n  .guarantees-inner {\n    max-width: 1000px;\n    margin: 0 auto;\n  }\n  .guarantees-label {\n    font-size: 13px;\n    font-weight: 500;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: #5a7a4a;\n    text-align: center;\n    margin-bottom: 0.75rem;\n  }\n  .guarantees-title {\n    font-size: 2.2rem;\n    font-weight: 500;\n    color: #1a1a1a;\n    text-align: center;\n    margin: 0 0 0.75rem;\n    line-height: 1.2;\n  }\n  .guarantees-subtitle {\n    font-size: 1rem;\n    color: #666;\n    text-align: center;\n    margin: 0 auto 3rem;\n    max-width: 480px;\n    line-height: 1.7;\n  }\n  .guarantees-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 1.5rem;\n  }\n  .guarantee-card {\n    background: #fff;\n    border-radius: 14px;\n    padding: 2rem 1.5rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    gap: 1rem;\n    border: 1px solid #ece9e1;\n  }\n  .guarantee-icon-wrap {\n    width: 64px;\n    height: 64px;\n    border-radius: 50%;\n    background: #f0f5eb;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n  .guarantee-icon-wrap i {\n    font-size: 28px;\n    color: #4a7a35;\n  }\n  .guarantee-name {\n    font-size: 1rem;\n    font-weight: 500;\n    color: #1a1a1a;\n    margin: 0 0 0.3rem;\n  }\n  .guarantee-desc {\n    font-size: 0.875rem;\n    color: #666;\n    line-height: 1.6;\n    margin: 0;\n  }\n  @media (max-width: 720px) {\n    .guarantees-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n    .guarantees-title {\n      font-size: 1.75rem;\n    }\n  }\n  @media (max-width: 400px) {\n    .guarantees-grid {\n      grid-
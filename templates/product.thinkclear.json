    "custom_liquid_W6qEE8": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" />\n\n<style>\n  .tc-section {\n    width: 100%;\n    padding: 5rem 2rem;\n    font-family: sans-serif;\n  }\n  .tc-inner {\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n  .tc-label {\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: #b07d3a;\n    margin-bottom: 0.5rem;\n  }\n  .tc-title {\n    font-size: 2rem;\n    font-weight: 500;\n    color: #1a1a1a;\n    line-height: 1.25;\n    margin-bottom: 0.6rem;\n  }\n  .tc-desc {\n    font-size: 0.95rem;\n    color: #777;\n    line-height: 1.6;\n    max-width: 480px;\n  }\n\n  /* ── INGREDIENTS ── */\n  .tc-ingredients { background: #fdf9f4; }\n\n  .tc-ing-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 3rem;\n    margin-top: 3rem;\n    align-items: center;\n  }\n  .tc-ing-list {\n    display: flex;\n    flex-direction: column;\n    gap: 1rem;\n  }\n  .tc-ing-item {\n    display: flex;\n    align-items: center;\n    gap: 1rem;\n    padding: 1.1rem 1.25rem;\n    background: #fff;\n    border-radius: 12px;\n    border: 1px solid #ece9e1;\n  }\n  .tc-ing-icon {\n    width: 42px;\n    height: 42px;\n    border-radius: 10px;\n    background: #fdf0de;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n  .tc-ing-icon i { font-size: 20px; color: #b07d3a; }\n  .tc-ing-name {\n    font-size: 0.9rem;\n    font-weight: 500;\n    color: #1a1a1a;\n    margin-bottom: 0.15rem;\n  }\n  .tc-ing-desc { font-size: 0.82rem; color: #999; line-height: 1.4; }\n  .tc-ing-img {\n    width: 100%;\n    aspect-ratio: 4/5;\n    border-radius: 16px;\n    object-fit: cover;\n    background: #e8ddd0;\n  }\n\n  /* ── HOW TO PREPARE ── */\n  .tc-prepare { background: #fff; }\n\n  .tc-steps {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 2rem;\n    margin-top: 3rem;\n  }\n  .tc-step { display: flex; flex-direction: column; gap: 0.85rem; }\n  .tc-step-num {\n    width: 38px;\n    height: 38px;\n    border-radius: 50%;\n    background: #1a1a1a;\n    color: #fff;\n    font-size: 0.85rem;\n    font-weight: 500;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .tc-step-title { font-size: 0.9rem; font-weight: 500; color: #1a1a1a; }\n  .tc-step-desc { font-size: 0.83rem; color: #888; line-height: 1.55; }\n  .tc-prepare-note {\n    margin-top: 2.5rem;\n    padding: 1rem 1.5rem;\n    background: #fff8ee;\n    border-left: 3px solid #b07d3a;\n    border-radius: 0 10px 10px 0;\n    font-size: 0.875rem;\n    color: #7a5520;\n    line-height: 1.6;\n  }\n\n  /* ── WHO IT'S FOR ── */\n  .tc-whofor { background: #1a1a1a; }\n  .tc-whofor .tc-label { color: #b07d3a; }\n  .tc-whofor .tc-title { color: #fff; }\n  .tc-whofor .tc-desc { color: #999; }\n\n  .tc-whofor-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 1.25rem;\n    margin-top: 3rem;\n  }\n  .tc-whofor-card {\n    padding: 1.75rem;\n    border-radius: 14px;\n    border: 1px solid #2e2e2e;\n    background: #222;\n    display: flex;\n    flex-direction: column;\n    gap: 0.65rem;\n  }\n  .tc-whofor-card i { font-size: 26px; color: #b07d3a; }\n  .tc-whofor-title { font-size: 0.9rem; font-weight: 500; color: #fff; }\n  .tc-whofor-desc { font-size: 0.83rem; color: #888; line-height: 1.55; }\n\n  /* ── REVIEWS ── */\n  .tc-reviews { background: #fdf9f4; }\n\n  .tc-reviews-header {\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n    flex-wrap: wrap;\n    gap: 1rem;\n    margin-bottom: 2.5rem;\n  }\n  .tc-rating-wrap { display: flex; align-items: center; gap: 0.75rem; }\n  .tc-rating-big { font-size: 2.5rem; font-weight: 500; color: #1a1a1a; line-height: 1; }\n  .tc-stars { display: flex; gap: 3px; }\n  .tc-stars i { font-size: 17px; color: #b07d3a; }\n  .tc-rating-count { font-size: 0.8rem; color: #aaa; margin-top: 3px; }\n\n  .tc-reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 1.25rem;\n  }\n  .tc-review-card {\n    background: #fff;\n    border-radius: 14px;\n    border: 1px solid #ece9e1;\n    padding: 1.5rem;\n    display: flex;\n    flex-direction: column;\n    gap: 0.85rem;\n  }\n  .tc-review-stars { display: flex; gap: 2px; }\n  .tc-review-stars i { font-size: 14px; color: #b07d3a; }\n  .tc-review-text { font-size: 0.875rem; color: #555; line-height: 1.65; flex: 1; }\n  .tc-review-author {\n    display: flex;\n    align-items: center;\n    gap: 0.75rem;\n    border-top: 1px solid #f0ede6;\n    padding-top: 1rem;\n  }\n  .tc-avatar {\n    width: 34px;\n    height: 34px;\n    border-radius: 50%;\n    background: #fdf0de;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 0.75rem;\n    font-weight: 600;\n    color: #b07d3a;\n    flex-shrink: 0;\n  }\n  .tc-review-name { font-size: 0.85rem; font-weight: 500; color: #1a1a1a; }\n  .tc-review-loc { font-size: 0.78rem; color: #bbb; }\n\n  /* ── RESPONSIVE ── */\n  @media (max-width: 860px) {\n    .tc-ing-grid { grid-template-columns: 1fr; }\n    .tc-ing-img { display: none; }\n    .tc-steps { grid-template-columns: repeat(2, 1fr); }\n    .tc-whofor-grid { grid-template-columns: 1fr 1fr; }\n    .tc-reviews-grid { grid-template-columns: 1fr 1fr; }\n  }\n  @media (max-width: 540px) {\n    .tc-section { padding: 3.5rem 1.25rem; }\n    .tc-title { font-size: 1.6rem; }\n    .tc-steps { grid-template-columns: 1fr; }\n    .tc-whofor-grid { grid-template-columns: 1fr; }\n    .tc-reviews-grid { grid-template-columns: 1fr; }\n  }\n</style>\n\n\n<!-- ── INGREDIENTS ── -->\n<section class=\"tc-section tc-ingredients\">\n  <div class=\"tc-inner\">\n    <p class=\"tc-label\">What's inside</p>\n    <h2 class=\"tc-title\">Pure ingredients,<br>powerful results</h2>\n    <p class=\"tc-desc\">One premium ingredient. Nothing hidden, nothing extra.</p>\n\n    <div class=\"tc-ing-grid\">\n      <div class=\"tc-ing-list\">\n\n        <div class=\"tc-ing-item\">\n          <div class=\"tc-ing-icon\"><i class=\"ti ti-leaf\" aria-hidden=\"true\"></i></div>\n          <div>\n            <p class=\"tc-ing-name\">Premium black tea leaves</p>\n            <p class=\"tc-ing-desc\">High-altitude sourced, full of natural caffeine and L-theanine.</p>\n          </div>\n        </div>\n\n        <div class=\"tc-ing-item\">\n          <div class=\"tc-ing-icon\"><i class=\"ti ti-brain\" aria-hidden=\"true\"></i></div>\n          <div>\n            <p class=\"tc-ing-name\">Natural caffeine</p>\n            <p class=\"tc-ing-desc\">Clean, sustained energy — no spikes, no crash.</p>\n          </div>\n        </div>\n\n        <div class=\"tc-ing-item\">\n          <div class=\"tc-ing-icon\"><i class=\"ti ti-wave-sine\" aria-hidden=\"true\"></i></div>\n          <div>\n            <p class=\"tc-ing-name\">L-theanine (naturally occurring)</p>\n            <p class=\"tc-ing-desc\">Calm alertness — focused without the jitters.</p>\n          </div>\n        </div>\n\n        <div class=\"tc-ing-item\">\n          <div class=\"tc-ing-icon\"><i class=\"ti ti-shield-check\" aria-hidden=\"true\"></i></div>\n          <div>\n            <p class=\"tc-ing-name\">Rich in antioxidants</p>\n            <p class=\"tc-ing-desc\">Polyphenols that support brain, gut, and immune health.</p>\n          </div>\n        </div>\n\n      </div>\n\n      <img class=\"tc-ing-img\" src=\"\" alt=\"Think Clear black tea\" onerror=\"this.style.background='#e8ddd0'\" />\n    </div>\n  </div>\n</section>\n\n\n<!-- ── HOW TO PREPARE ── -->\n<section class=\"tc-section tc-prepare\">\n  <div class=\"tc-inner\">\n    <p class=\"tc-label\">Brew guide</p>\n    <h2 class=\"tc-title\">Your perfect cup,<br>every time</h2>\n\n    <div class=\"tc-steps\">\n\n      <div class=\"tc-step\">\n        <div class=\"tc-step-num\">1</div>\n        <p class=\"tc-step-title\">Heat your water</p>\n        <p class=\"tc-step-desc\">90–95°C. Not a full boil — it preserves the flavor and benefits.</p>\n      </div>\n\n      <div class=\"tc-step\">\n        <div class=\"tc-step-num\">2</div>\n        <p class=\"tc-step-title\">Measure one teaspoon</p>\n        <p class=\"tc-step-desc\">Add to your cup or infuser. Adjust to taste.</p>\n      </div>\n\n      <div class=\"tc-step\">\n        <div class=\"tc-step-num\">3</div>\n        <p class=\"tc-step-title\">Steep 3–5 minutes</p>\n        <p class=\"tc-step-desc\">Longer steep = bolder, stronger brew.</p>\n      </div>\n\n      <div class=\"tc-step\">\n        <div class=\"tc-step-num\">4</div>\n        <p class=\"tc-step-title\">Sip & focus</p>\n        <p class=\"tc-step-desc\">Best in the morning or early afternoon.</p>\n      </div>\n\n    </div>\n\n    <div class=\"tc-prepare-note\">\n      <strong>Best time to drink:</strong> Morning or early afternoon — when your mind needs to be at its sharpest.\n    </div>\n  </div>\n</section>\n\n\n<!-- ── WHO IT'S FOR ── -->\n<section class=\"tc-section tc-whofor\">\n  <div class=\"tc-inner\">\n    <p class=\"tc-label\">Made for you if...</p>\n    <h2 class=\"tc-title\">Who Think Clear<br>is made for</h2>\n    <p class=\"tc-desc\">Your daily mental edge — whoever you are, whatever you're building.</p>\n\n    <div class=\"tc-whofor-grid\">\n\n      <div class=\"tc-whofor-card\">\n        <i class=\"ti ti-device-laptop\" aria-hidden=\"true\"></i>\n        <p class=\"tc-whofor-title\">Professionals & remote workers</p>\n        <p class=\"tc-whofor-desc\">Stay sharp through back-to-back meetings and long work sessions.</p>\n      </div>\n\n      <div class=\"tc-whofor-card\">\n        <i class=\"ti ti-book\" aria-hidden=\"true\"></i>\n        <p class=\"tc-whofor-title\">Students & learners</p>\n        <p class=\"tc-whofor-desc\">Sharpen retention and stay in the zone when it counts most.</p>\n      </div>\n\n      <div class=\"tc-whofor-card\">\n        <i class=\"ti ti-coffee\" aria-hidden=\"true\"></i>\n        <p class=\"tc-whofor-title\">Coffee switchers</p>\n        <p class=\"tc-whofor-desc\">Same lift, zero jitters. A smoother, cleaner alternative.</p>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n\n<!-- ── REVIEWS ── -->\n<section class=\"tc-section tc-reviews\">\n  <div class=\"tc-inner\">\n    <div class=\"tc-reviews-header\">\n      <div>\n        <p class=\"tc-label\">What people say</p>\n        <h2 class=\"tc-title\">Real results,<br>real people</h2>\n      </div>\n      <div class=\"tc-rating-wrap\">\n        <span class=\"tc-rating-big\">4.9</span>\n        <div>\n          <div class=\"tc-stars\">\n            <i class=\"ti ti-star-filled\" aria-hidden=\"true\"></i>\n            <i class=\"ti ti-star-filled\" aria-hidden=\"true\"></i>\n            <i class=\"ti ti-star-filled\" aria-hidden=\"true\"></i>\n            <i class=\"ti ti-star-filled\" aria-hidden=\"true\"></i>\n            <i class=\"ti ti-star-filled\" aria-hidden=\"true\"></i>\n          </div>\n          <p class=\"tc-rating-count\">128 verified reviews</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"tc-reviews-grid\">\n\n      <div class=\"tc-review-card\">\n        <div class=\"tc-review-stars\">\n          <i class=\"ti ti-star-filled\" aria-hidden=\"true\"></i>\n          <i class=\"ti ti-star-filled\" aria-hidden=\"true\"></i>\n          <i class=\"ti ti-star-filled\" aria-hidden=\"true\"></i>\n          <i class=\"ti ti-star-filled\" aria-hidden=\"true\"></i>\n          <i class=\"ti ti-star-filled\" aria-hidden=\"true\"></i>\n        </div>\n        <p class=\"tc-review-text\">\"Switched from coffee three weeks ago. No crash, no jitters — just steady focus all day. My productivity has genuinely improved.\"</p>\n        <div class=\"tc-review-author\">\n          <div class=\"tc-avatar\">LM</div>\n          <div>\n            <p class=\"tc-review-name\">Layla M.</p>\n     